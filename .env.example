# Your Telegram Bot Token (get it from @BotFather)
BOT_TOKEN = "YOUR_BOT_TOKEN_HERE"

# Your Telegram user ID (send /ping to the bot to find ou & add the id insted of 0)
# Only this user can access /ping command
ADMIN_ID = 0

# Instagram (Optional)
# Uncomment and fill these for private Instagram content
# INSTAGRAM_USERNAME = your_username
# INSTAGRAM_PASSWORD = your_password

# Self-Hosted Bot API Server (Optional)
# Set USE_LOCAL_API = true to bypass Telegram's 50MB upload limit (up to 2GB)
# Requires a running local Bot API server (see README for setup)

USE_LOCAL_API = false

# Only needed when USE_LOCAL_API = true 
# TELEGRAM_API_ID = YOUR_API_ID
# TELEGRAM_API_HASH = YOUR_API_HASH
# LOCAL_API_SERVER = http://localhost:8081

# Advanced (Optional — defaults are fine)
# MAX_FILE_SIZE_MB = 49        # Auto-adjusts: 49 for official API, 1999 for local
# MAX_PLAYLIST_SIZE = 50       # Max videos to download from a playlist
# PROGRESS_UPDATE_INTERVAL = 3.0